# Turso Database
# Obtenez ces valeurs sur https://turso.tech → votre base de données → "Connect"
TURSO_DATABASE_URL=libsql://votre-base.turso.io
TURSO_AUTH_TOKEN=eyJhb...votre_token

# Secret pour protéger le cron job automatique (mettez n'importe quelle chaîne aléatoire)
CRON_SECRET=changez-moi-par-un-mot-de-passe-aleatoire

# Pappers API — enrichissement LinkedIn
# Obtenez votre clé sur https://www.pappers.fr/api → "Obtenir une clé API"
PAPPERS_API_TOKEN=votre_token_pappers

# Anthropic Claude API — qualification commerciale automatique
# Obtenez votre clé sur https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...votre_cle

# (Optionnel) INSEE SIRENE API — fallback si l'API ouverte est indisponible
# Obtenez un accès sur https://api.insee.fr
# SIRENE_API_KEY=votre_token_insee
