# Turso Database
# Obtenez ces valeurs sur https://turso.tech → votre base de données → "Connect"
TURSO_DATABASE_URL=libsql://votre-base.turso.io
TURSO_AUTH_TOKEN=eyJhb...votre_token

# Secret pour protéger le cron job automatique (mettez n'importe quelle chaîne aléatoire)
CRON_SECRET=changez-moi-par-un-mot-de-passe-aleatoire
